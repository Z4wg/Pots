# Copy to .env and fill in your Supabase project values.
# Project Settings -> API in the Supabase dashboard.
# These EXPO_PUBLIC_ vars are read by lib/supabase.ts at build time.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Only needed to run scripts/setup-supabase.mjs (applies schema.sql + seed.sql).
# Project Settings -> Database -> Connection string -> URI (use the value that
# includes your password). Keep this secret; never ship it in the app.
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres
